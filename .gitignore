__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
*.egg-info/

# ── node / playwright ──────────────────────────────────────────
node_modules/
test-results/
playwright-report/
.playwright/
blob-report/

# ── os / local tooling ─────────────────────────────────────────
.DS_Store
.claude/settings.local.json

# ── archives / build cruft ─────────────────────────────────────
*.zip
