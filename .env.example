ANTHROPIC_API_KEY=your_key_here
DB_PATH=data/finance.db
OUTPUT_FOLDER=data/exports
UPLOAD_FOLDER=data/uploads
# Months before this read from bootstrapped sheet history; from it onward, live transactions
LIVE_START_MONTH=2026-05
# macOS AirPlay Receiver occupies port 5000 — use 5001
PORT=5001
# Schwab Trader API (free; developer.schwab.com — see README "Schwab direct sync")
SCHWAB_APP_KEY=
SCHWAB_APP_SECRET=
SCHWAB_CALLBACK_URL=https://127.0.0.1
# Plaid bank/credit sync (OPTIONAL — leave blank to keep CSV-only). dashboard.plaid.com
# Sandbox is free (fake data); set PLAID_ENV=production for real banks (Trial = 10 free).
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Ticker of your employer's stock (OPTIONAL) — powers the investments-page
# concentration check and defaults the RSU-vest form's symbol. Leave blank to skip.
EMPLOYER_STOCK_SYMBOL=
